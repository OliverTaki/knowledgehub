{
  "name": "interest-wiki-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:x": "node scripts/x-auth-login.mjs",
    "collect:x-likes": "node scripts/x-collect-likes.mjs",
    "build:wire": "node scripts/build-wire.mjs",
    "build:site": "node scripts/build-site.mjs",
    "run:daily": "node scripts/x-collect-likes.mjs && node scripts/build-wire.mjs && node scripts/build-site.mjs",
    "validate": "node scripts/validate-jsonl.mjs",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "dependencies": {
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "wrangler": "^4.85.0"
  }
}
